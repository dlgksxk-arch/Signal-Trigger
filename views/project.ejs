<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= (project.topic || '').split(/\r?\n/)[0] %> - <%= versionLabel %></title>
    <link rel="stylesheet" href="/public/app.css" />
    <script src="/public/app.js" defer></script>
  </head>
  <body class="app-body dark-body">
    <div class="studio-shell">
      <aside class="studio-sidebar workflow-sidebar">
        <div class="studio-logo">
          <div class="studio-logo-mark">LF</div>
          <div>
            <strong>Production Flow</strong>
            <span><%= versionLabel %></span>
          </div>
        </div>

        <nav class="studio-nav workflow-nav">
          <a class="studio-nav-item" href="/workspace/dashboard">
            <span class="studio-nav-dot"></span>
            <div>
              <strong>Studio 대시보드</strong>
              <span>Back</span>
            </div>
          </a>

          <% steps.forEach((step) => { %>
            <a
              class="studio-nav-item workflow-nav-item <%= step.active ? 'active' : '' %> <%= step.statusKey %>"
              href="<%= step.href %>"
              data-workflow-link
              data-step-target="<%= step.key %>"
              data-step-label="<%= step.label %>"
              data-step-href="<%= step.href %>"
            >
              <span class="workflow-step-marker <%= step.statusKey %>"><%= step.label.split('. ')[0] %></span>
              <div class="workflow-step-meta">
                <div class="workflow-step-header">
                  <strong><%= step.shortLabel %></strong>
                  <span class="workflow-step-status <%= step.statusKey %>"><%= step.statusLabel %></span>
                </div>
                <span><%= step.detail %></span>
              </div>
            </a>
          <% }) %>
        </nav>

        <section class="studio-side-card">
          <p class="section-tag">Project</p>
          <ul class="studio-side-list">
            <li>상태: <strong><%= project.status %></strong></li>
            <li>채널: <strong><%= project.channel_name || '미선택' %></strong></li>
            <li>예약: <strong><%= project.scheduled_at || '없음' %></strong></li>
            <li>길이: <strong>약 <%= project.settings?.durationMinutes || 10 %>분</strong></li>
          </ul>
        </section>
      </aside>

      <main class="studio-main workflow-page" data-active-step="<%= activeStep %>" data-auto-refresh="<%= generationView.autoRefresh ? 'true' : 'false' %>">
        <section class="topbar-card">
          <div>
            <a class="back-link" href="/workspace/projects">프로젝트 보관함으로</a>
            <p class="section-tag">Project Editor</p>
            <h1><%= (project.topic || '').split(/\r?\n/)[0] %></h1>
            <p class="lead-text">왼쪽에서 작업 단계를 고르고, 가운데에서 해당 단계만 집중 편집합니다. 현재 목표 영상 길이는 약 <%= project.settings?.durationMinutes || 10 %>분입니다.</p>
            <div class="form-actions topbar-actions">
              <form action="/projects/<%= project.id %>/delete" method="post" data-delete-project-form>
                <input type="hidden" name="returnTo" value="projects" />
                <button class="danger-button" type="submit">프로젝트 삭제</button>
              </form>
            </div>
          </div>
          <div class="editor-summary">
            <div class="metric-card primary-metric">
              <span class="metric-label">현재 단계</span>
              <strong data-current-step-label><%= steps.find((item) => item.active)?.label || '1. 주제 설정' %></strong>
            </div>
            <div class="metric-card">
              <span class="metric-label">장면 수</span>
              <strong><%= project.scenes.length %></strong>
            </div>
          </div>
        </section>

        <% if (noticeMessage) { %>
          <section class="notice-banner">
            <strong>알림</strong>
            <span><%= noticeMessage %></span>
          </section>
        <% } %>

        <section class="panel-card generation-card">
          <div class="panel-header">
            <div>
              <p class="section-tag">Auto Generation</p>
              <h2>전체 자동 생성 진행상황</h2>
              <p class="card-copy"><strong><%= generationView.stateLabel %></strong> · <%= generationView.currentLabel %> · <%= generationView.detail %></p>
            </div>
            <div class="form-actions">
              <% if (generationView.state === 'running' || generationView.state === 'pause_requested') { %>
                <form action="/projects/<%= project.id %>/automation/pause" method="post">
                  <input type="hidden" name="returnStep" value="<%= activeStep %>" />
                  <button type="submit">일시중지</button>
                </form>
              <% } else { %>
                <form action="/projects/<%= project.id %>/automation/start" method="post">
                  <input type="hidden" name="returnStep" value="<%= activeStep %>" />
                  <button type="submit">전체 자동 생성</button>
                </form>
              <% } %>

              <% if (generationView.state === 'paused') { %>
                <form action="/projects/<%= project.id %>/automation/resume" method="post">
                  <input type="hidden" name="returnStep" value="<%= activeStep %>" />
                  <button class="dark-button" type="submit">재개</button>
                </form>
              <% } %>

              <% if (generationView.state !== 'idle') { %>
                <form action="/projects/<%= project.id %>/automation/reset" method="post" data-reset-form>
                  <input type="hidden" name="returnStep" value="<%= activeStep %>" />
                  <button class="dark-button" type="submit">초기화</button>
                </form>
              <% } %>
            </div>
          </div>

          <div class="generation-progress">
            <div class="generation-progress-track">
              <div class="generation-progress-fill <%= generationView.state %>" style="width: <%= generationView.percent %>%"></div>
            </div>
            <div class="generation-progress-meta">
              <span class="status-chip"><%= generationView.percent %>%</span>
              <span class="status-chip">현재 단계 <%= generationView.currentLabel %></span>
              <% if (generationView.sceneTotal) { %>
                <span class="status-chip">장면 <%= generationView.sceneCurrent %>/<%= generationView.sceneTotal %></span>
              <% } %>
            </div>
            <% if (generationView.error) { %>
              <p class="generation-error"><%= generationView.error %></p>
            <% } %>
          </div>
        </section>

        <section class="content-grid editor-grid">
          <section class="content-stack workflow-panels">
            <article class="panel-card workflow-panel <%= activeStep === 'topic' ? 'active' : '' %>" data-step-panel="topic">
              <div class="panel-header">
                <div>
                  <p class="section-tag">Step 1</p>
                  <h2>주제 설정</h2>
                  <p class="card-copy">주제 프롬프트를 저장하면 아래 도출된 주제가 실제 프로젝트 주제로 사용됩니다.</p>
                </div>
                <span class="status-chip">프롬프트 입력</span>
              </div>

              <form class="form-grid studio-form" action="/projects/<%= project.id %>/settings" method="post" enctype="multipart/form-data">
                <label class="wide">주제 프롬프트
                  <textarea
                    name="topicPrompt"
                    class="prompt-textarea"
                    placeholder="예: 오늘 가장 주목해야 할 반도체 시장 이슈를 3개로 정리하고, 각 이슈가 업계와 투자자에게 주는 영향을 설명해 주세요."
                  ><%= topicPromptText %></textarea>
                </label>

                <label>언어
                  <select name="language">
                    <option value="ko" <%= project.language === 'ko' ? 'selected' : '' %>>한국어</option>
                    <option value="en" <%= project.language === 'en' ? 'selected' : '' %>>영어</option>
                    <option value="ja" <%= project.language === 'ja' ? 'selected' : '' %>>일본어</option>
                  </select>
                </label>

                <label>톤
                  <input type="text" name="tone" value="<%= project.tone %>" />
                </label>

                <label>화면 비율
                  <select name="format">
                    <option value="portrait" <%= project.format === 'portrait' ? 'selected' : '' %>>세로형 9:16</option>
                    <option value="landscape" <%= project.format === 'landscape' ? 'selected' : '' %>>가로형 16:9</option>
                  </select>
                </label>

                <label>영상 길이
                  <select name="durationMinutes">
                    <% durationOptions.forEach((minutes) => { %>
                      <option value="<%= minutes %>" <%= (project.settings?.durationMinutes || 10) === minutes ? 'selected' : '' %>><%= minutes %>분</option>
                    <% }) %>
                  </select>
                </label>

                <label>채널
                  <select name="channelId">
                    <option value="">선택 안 함</option>
                    <% channels.forEach((channel) => { %>
                      <option value="<%= channel.id %>" <%= project.channel_id === channel.id ? 'selected' : '' %>><%= channel.name %></option>
                    <% }) %>
                  </select>
                </label>

                <label>예약 시작
                  <input type="datetime-local" name="scheduledAt" value="<%= project.scheduled_at ? project.scheduled_at.slice(0, 16) : '' %>" />
                </label>

                <label class="wide">추가 지시
                  <input type="text" name="customPrompt" value="<%= project.settings?.customPrompt || '' %>" />
                </label>

                <label>스타일 레퍼런스
                  <input type="file" name="styleReference" accept="image/*" />
                  <small>현재 파일: <%= optionFiles.styleReferenceName || '없음' %></small>
                  <span class="inline-check"><input type="checkbox" name="clearStyleReference" value="true" /> 현재 파일 삭제</span>
                </label>

                <label>BGM 파일
                  <input type="file" name="bgmFile" accept="audio/*" />
                  <small>현재 파일: <%= optionFiles.bgmName || '없음' %></small>
                  <span class="inline-check"><input type="checkbox" name="clearBgmFile" value="true" /> 현재 파일 삭제</span>
                </label>

                <label class="wide">워터마크
                  <input type="file" name="watermarkFile" accept="image/*" />
                  <small>현재 파일: <%= optionFiles.watermarkName || '없음' %></small>
                  <span class="inline-check"><input type="checkbox" name="clearWatermarkFile" value="true" /> 현재 파일 삭제</span>
                </label>

                <div class="wide form-actions">
                  <button type="submit">주제 설정 저장</button>
                </div>
              </form>

              <section class="saved-preview-card">
                <div class="panel-header preview-header">
                  <div>
                    <p class="section-tag">Resolved Topic</p>
                    <h3>도출된 주제</h3>
                  </div>
                </div>
                <div class="soft-card">
                  <h3><%= project.topic || '아직 도출된 주제가 없습니다.' %></h3>
                  <p>리서치와 대본 생성은 이 도출된 주제를 기준으로 진행됩니다.</p>
                </div>
              </section>
            </article>

            <article class="panel-card workflow-panel <%= activeStep === 'research' ? 'active' : '' %>" data-step-panel="research">
              <div class="panel-header">
                <div>
                  <p class="section-tag">Step 2</p>
                  <h2>소재 발굴</h2>
                  <p class="card-copy">자동 수집을 누르면 도출된 주제 기준으로 리서치를 불러오고, 저장하면 바로 아래에 반영됩니다.</p>
                </div>
                <form action="/projects/<%= project.id %>/research/auto" method="post">
                  <button type="submit">자동 수집</button>
                </form>
              </div>

              <form class="form-grid studio-form" action="/projects/<%= project.id %>/research/manual" method="post">
                <label class="wide">요약
                  <textarea name="summary"><%= researchSummaryText %></textarea>
                </label>
                <label class="wide">아이디어 목록
                  <textarea name="ideas"><%= researchIdeasText %></textarea>
                </label>
                <label class="wide">수동 메모
                  <textarea name="manualNotes"><%= researchNotesText %></textarea>
                </label>
                <div class="wide form-actions">
                  <button type="submit">리서치 저장</button>
                </div>
              </form>

              <section class="saved-preview-card">
                <div class="panel-header preview-header">
                  <div>
                    <p class="section-tag">Saved Research</p>
                    <h3>저장된 리서치 내용</h3>
                  </div>
                  <span class="status-chip">최근 저장 시각 <%= project.updated_at?.slice(0, 16).replace('T', ' ') || '-' %></span>
                </div>

                <% if (project.research) { %>
                  <div class="saved-preview-grid">
                    <div class="soft-card">
                      <h3>도출된 주제</h3>
                      <p><%= project.research.selectedTopic || project.topic %></p>
                    </div>
                    <div class="soft-card">
                      <h3>저장 요약</h3>
                      <p><%= project.research.summary || '저장된 요약이 없습니다.' %></p>
                    </div>
                    <div class="soft-card">
                      <h3>저장 아이디어</h3>
                      <% if ((project.research.ideas || []).length) { %>
                        <ul class="preview-list">
                          <% project.research.ideas.forEach((idea) => { %>
                            <li><%= idea %></li>
                          <% }) %>
                        </ul>
                      <% } else { %>
                        <p>저장된 아이디어가 없습니다.</p>
                      <% } %>
                    </div>
                    <div class="soft-card">
                      <h3>수동 메모</h3>
                      <p><%= project.research.manualNotes || '저장된 메모가 없습니다.' %></p>
                    </div>
                  </div>
                <% } else { %>
                  <div class="empty-card">
                    <strong>아직 저장된 리서치가 없습니다.</strong>
                    <p>자동 수집 또는 리서치 저장을 먼저 실행해 주세요.</p>
                  </div>
                <% } %>
              </section>
            </article>

            <article class="panel-card workflow-panel <%= activeStep === 'script' ? 'active' : '' %>" data-step-panel="script">
              <div class="panel-header">
                <div>
                  <p class="section-tag">Step 3</p>
                  <h2>대본 작성</h2>
                  <p class="card-copy">현재 설정된 영상 길이 기준으로 약 <%= project.settings?.durationMinutes || 10 %>분 분량 대본을 생성합니다.</p>
                </div>
                <div class="form-actions">
                  <form action="/projects/<%= project.id %>/bootstrap" method="post">
                    <button type="submit">주제부터 대본까지 자동</button>
                  </form>
                  <form action="/projects/<%= project.id %>/script/auto" method="post">
                    <button class="dark-button" type="submit">대본 자동 생성</button>
                  </form>
                </div>
              </div>

              <div class="info-row">
                <span class="status-chip">도출된 주제 <%= project.topic %></span>
                <span class="status-chip">목표 길이 <%= project.settings?.durationMinutes || 10 %>분</span>
              </div>

              <form class="form-grid studio-form" action="/projects/<%= project.id %>/script/manual" method="post">
                <label class="wide">대본
                  <textarea name="script" class="tall-textarea"><%= project.script_text || '' %></textarea>
                </label>
                <div class="wide form-actions">
                  <button type="submit">대본 저장</button>
                </div>
              </form>
            </article>

            <article class="panel-card workflow-panel <%= activeStep === 'scenes' ? 'active' : '' %>" data-step-panel="scenes">
              <div class="panel-header">
                <div>
                  <p class="section-tag">Step 4</p>
                  <h2>장면 편집</h2>
                  <p class="card-copy">장면 카드와 장면 단위 재생성을 관리합니다.</p>
                </div>
                <form action="/projects/<%= project.id %>/run" method="post">
                  <button type="submit">장면 생성 또는 갱신</button>
                </form>
              </div>

              <div class="card-grid scene-grid">
                <% if (!project.scenes.length) { %>
                  <div class="empty-card">
                    <strong>아직 장면이 없습니다.</strong>
                    <p>렌더 실행 또는 장면 생성을 먼저 진행해 주세요.</p>
                  </div>
                <% } %>
                <% project.scenes.forEach((scene, index) => { %>
                  <article class="scene-card <%= project.format %>">
                    <% if (scene.imagePath) { %>
                      <button
                        type="button"
                        class="scene-thumb-button"
                        data-scene-open
                        data-scene-title="Scene <%= index + 1 %>"
                        data-scene-image="<%= scene.imagePath.replace(/^.*?storage/, '/storage').replace(/\\/g, '/') %>"
                        data-scene-prompt="<%= scene.imagePrompt %>"
                        data-scene-narration="<%= scene.narration %>"
                        data-scene-action="/projects/<%= project.id %>/scenes/<%= index %>/regenerate"
                      >
                        <span class="scene-number-badge"><%= index + 1 %></span>
                        <img
                          class="scene-thumb-image"
                          src="<%= scene.imagePath.replace(/^.*?storage/, '/storage').replace(/\\/g, '/') %>"
                          alt="Scene <%= index + 1 %>"
                        />
                      </button>
                    <% } else { %>
                      <div class="scene-thumb-placeholder">
                        <span class="scene-number-badge"><%= index + 1 %></span>
                      </div>
                    <% } %>
                  </article>
                <% }) %>
              </div>
            </article>

            <article class="panel-card workflow-panel <%= activeStep === 'render' ? 'active' : '' %>" data-step-panel="render">
              <div class="panel-header">
                <div>
                  <p class="section-tag">Step 5</p>
                  <h2>렌더 결과</h2>
                  <p class="card-copy">영상, 썸네일, 자막 결과를 확인합니다.</p>
                </div>
                <form action="/projects/<%= project.id %>/run" method="post">
                  <button type="submit">전체 다시 렌더</button>
                </form>
              </div>

              <div class="action-grid">
                <% if (project.output?.videoPath) { %>
                  <a class="action-card" href="<%= project.output.videoPath.replace(/^.*?storage/, '/storage') %>" target="_blank">
                    <strong>완성 영상 열기</strong>
                    <p>렌더된 최종 mp4 파일을 확인합니다.</p>
                  </a>
                <% } %>
                <% if (project.output?.thumbnailPath) { %>
                  <a class="action-card" href="<%= project.output.thumbnailPath.replace(/^.*?storage/, '/storage') %>" target="_blank">
                    <strong>썸네일 열기</strong>
                    <p>생성된 썸네일 파일을 확인합니다.</p>
                  </a>
                <% } %>
                <% if (project.output?.subtitlesPath) { %>
                  <a class="action-card" href="<%= project.output.subtitlesPath.replace(/^.*?storage/, '/storage') %>" target="_blank">
                    <strong>자막 열기</strong>
                    <p>생성된 자막 파일을 확인합니다.</p>
                  </a>
                <% } %>
                <% if (!project.output?.videoPath && !project.output?.thumbnailPath && !project.output?.subtitlesPath) { %>
                  <div class="empty-card">
                    <strong>렌더 결과가 없습니다.</strong>
                    <p>전체 렌더를 먼저 실행해 주세요.</p>
                  </div>
                <% } %>
              </div>
            </article>

            <article class="panel-card workflow-panel <%= activeStep === 'publish' ? 'active' : '' %>" data-step-panel="publish">
              <div class="panel-header">
                <div>
                  <p class="section-tag">Step 6</p>
                  <h2>업로드 및 연동</h2>
                  <p class="card-copy">결과물 패키지와 도움말 기능을 확인합니다.</p>
                </div>
              </div>

              <div class="content-stack">
                <section class="soft-card">
                  <h3>Google Vids 자산</h3>
                  <% googleVidsNotes.forEach((note) => { %>
                    <p><%= note %></p>
                  <% }) %>
                  <a class="inline-link" href="/api/projects/<%= project.id %>/google-vids-package" target="_blank">Google Vids용 자산 패키지 JSON 열기</a>
                </section>

                <section class="soft-card">
                  <h3>GitHub 연결 상태</h3>
                  <p>로컬 Git 준비: <strong><%= githubStatus.localGitReady ? '완료' : '미완료' %></strong></p>
                  <p>원격 GitHub 연결: <strong><%= githubStatus.remoteConnected ? '완료' : '대기' %></strong></p>
                  <p><%= githubStatus.note %></p>
                </section>

                <section class="soft-card">
                  <h3>도움말 챗봇</h3>
                  <form class="form-grid single-form studio-form" action="/projects/<%= project.id %>/help" method="post">
                    <label>질문
                      <input type="text" name="question" placeholder="예: 업로드 전에 확인할 것은?" />
                    </label>
                    <div class="form-actions">
                      <button type="submit">질문하기</button>
                    </div>
                  </form>
                  <% if (typeof helpAnswer !== 'undefined') { %>
                    <p class="help-answer"><%= helpAnswer %></p>
                  <% } %>
                </section>
              </div>
            </article>
          </section>

          <aside class="content-stack narrow-stack">
            <article class="panel-card sticky-panel">
              <div class="panel-header">
                <div>
                  <p class="section-tag">Inspector</p>
                  <h2>프로젝트 요약</h2>
                </div>
              </div>
              <div class="mini-metrics">
                <div class="metric-card primary-metric">
                  <span class="metric-label">상태</span>
                  <strong><%= project.status %></strong>
                </div>
                <div class="metric-card">
                  <span class="metric-label">언어</span>
                  <strong><%= project.language %></strong>
                </div>
                <div class="metric-card">
                  <span class="metric-label">길이</span>
                  <strong><%= project.settings?.durationMinutes || 10 %>분</strong>
                </div>
              </div>
            </article>
          </aside>
        </section>
      </main>
    </div>

    <div class="scene-modal" data-scene-modal hidden>
      <div class="scene-modal-backdrop" data-scene-close></div>
      <div class="scene-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="scene-modal-title">
        <div class="scene-modal-header">
          <div>
            <p class="section-tag">Scene Detail</p>
