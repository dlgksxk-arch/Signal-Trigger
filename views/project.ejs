<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= project.topic %> - <%= versionLabel %></title>
    <link rel="stylesheet" href="/public/app.css" />
  </head>
  <body>
    <main class="workspace">
      <header class="workspace-topbar">
        <div>
          <a class="back-link" href="/">목록으로</a>
          <p class="eyebrow">Longform Workflow <%= versionLabel %></p>
          <h1><%= project.topic %></h1>
          <p class="sub"><%= project.language %> · <%= project.tone %> · <%= project.format %> · 상태 <strong><%= project.status %></strong></p>
        </div>
        <div class="top-actions">
          <form action="/projects/<%= project.id %>/bootstrap" method="post">
            <button type="submit">주제부터 대본까지 자동</button>
          </form>
          <form action="/projects/<%= project.id %>/run" method="post">
            <button class="dark-button" type="submit">전체 렌더 실행</button>
          </form>
        </div>
      </header>

      <section class="workspace-body">
        <aside class="workflow-sidebar">
          <div class="sidebar-card">
            <p class="eyebrow">워크플로우</p>
            <nav class="workflow-steps">
              <% steps.forEach((step) => { %>
                <a class="workflow-step <%= step.active ? 'active' : '' %>" href="<%= step.href %>">
                  <span class="step-dot <%= step.done ? 'done' : '' %>"></span>
                  <span><%= step.label %></span>
                </a>
              <% }) %>
            </nav>
          </div>

          <div class="sidebar-card">
            <p class="eyebrow">현재 상태</p>
            <dl class="meta-list">
              <div><dt>예약</dt><dd><%= project.scheduled_at || '없음' %></dd></div>
              <div><dt>채널</dt><dd><%= project.channel_name || '미지정' %></dd></div>
              <div><dt>업로드</dt><dd><%= project.output?.uploadStatus || 'pending' %></dd></div>
            </dl>
          </div>
        </aside>

        <section class="workflow-main">
          <% if (activeStep === 'topic') { %>
            <article class="panel">
              <div class="panel-head">
                <div>
                  <p class="eyebrow">1단계</p>
                  <h2>주제 설정</h2>
                </div>
              </div>

              <form class="form-grid" action="/projects/<%= project.id %>/settings" method="post">
                <label>주제
                  <input type="text" name="topic" value="<%= project.topic %>" />
                </label>

                <label>언어
                  <select name="language">
                    <option value="ko" <%= project.language === 'ko' ? 'selected' : '' %>>한국어</option>
                    <option value="en" <%= project.language === 'en' ? 'selected' : '' %>>영어</option>
                    <option value="ja" <%= project.language === 'ja' ? 'selected' : '' %>>일본어</option>
                  </select>
                </label>

                <label>톤
                  <input type="text" name="tone" value="<%= project.tone %>" />
                </label>

                <label>화면 비율
                  <select name="format">
                    <option value="portrait" <%= project.format === 'portrait' ? 'selected' : '' %>>세로형 9:16</option>
                    <option value="landscape" <%= project.format === 'landscape' ? 'selected' : '' %>>가로형 16:9</option>
                  </select>
                </label>

                <label>채널
                  <select name="channelId">
                    <option value="">선택 안 함</option>
                    <% channels.forEach((channel) => { %>
                      <option value="<%= channel.id %>" <%= project.channel_id === channel.id ? 'selected' : '' %>><%= channel.name %></option>
                    <% }) %>
                  </select>
                </label>

                <label>예약 시각
                  <input type="datetime-local" name="scheduledAt" value="<%= project.scheduled_at ? project.scheduled_at.slice(0, 16) : '' %>" />
                </label>

                <label class="wide">추가 지시
                  <input type="text" name="customPrompt" value="<%= project.settings?.customPrompt || '' %>" />
                </label>

                <div class="wide action-row">
                  <button type="submit">주제 저장</button>
                  <a class="ghost-button" href="/projects/<%= project.id %>?step=research">다음 단계로</a>
                </div>
              </form>
            </article>
          <% } %>

          <% if (activeStep === 'research') { %>
            <article class="panel">
              <div class="panel-head">
                <div>
                  <p class="eyebrow">2단계</p>
                  <h2>소재 발굴</h2>
                </div>
                <form action="/projects/<%= project.id %>/research/auto" method="post">
                  <button type="submit">자동 수집</button>
                </form>
              </div>

              <form class="form-grid" action="/projects/<%= project.id %>/research/manual" method="post">
                <label class="wide">요약
                  <textarea name="summary"><%= researchSummaryText %></textarea>
                </label>

                <label class="wide">키워드 목록
                  <textarea name="ideas"><%= researchIdeasText %></textarea>
                </label>

                <label class="wide">수동 메모
                  <textarea name="manualNotes"><%= researchNotesText %></textarea>
                </label>

                <div class="wide action-row">
                  <button type="submit">리서치 저장</button>
                  <a class="ghost-button" href="/projects/<%= project.id %>?step=script">대본 단계로</a>
                </div>
              </form>
            </article>
          <% } %>

          <% if (activeStep === 'script') { %>
            <article class="panel">
              <div class="panel-head">
                <div>
                  <p class="eyebrow">3단계</p>
                  <h2>대본 작성</h2>
                </div>
                <form action="/projects/<%= project.id %>/script/auto" method="post">
                  <button type="submit">대본 자동 생성</button>
                </form>
              </div>

              <form class="form-grid" action="/projects/<%= project.id %>/script/manual" method="post">
                <label class="wide">대본
                  <textarea name="script" class="tall-textarea"><%= project.script_text || '' %></textarea>
                </label>

                <div class="wide action-row">
                  <button type="submit">대본 저장</button>
                  <a class="ghost-button" href="/projects/<%= project.id %>?step=scenes">장면 단계로</a>
                </div>
              </form>
            </article>
          <% } %>

          <% if (activeStep === 'scenes') { %>
            <article class="panel">
              <div class="panel-head">
                <div>
                  <p class="eyebrow">4단계</p>
                  <h2>장면 편집</h2>
                </div>
                <form action="/projects/<%= project.id %>/run" method="post">
                  <button type="submit">장면 생성 또는 갱신</button>
                </form>
              </div>

              <div class="scene-grid">
                <% if (!project.scenes.length) { %>
                  <p class="empty">아직 장면이 없습니다. 먼저 렌더 실행을 눌러 장면을 생성해 주세요.</p>
                <% } %>

                <% project.scenes.forEach((scene, index) => { %>
                  <article class="scene-card">
                    <% if (scene.imagePath) { %>
                      <img src="<%= scene.imagePath.replace(/^.*?storage/, '/storage') %>" alt="<%= scene.title %>" />
                    <% } %>
                    <h3><%= scene.title %></h3>
                    <p><%= scene.narration %></p>
                    <small><%= scene.imagePrompt %></small>
                    <form action="/projects/<%= project.id %>/scenes/<%= index %>/regenerate" method="post">
                      <button type="submit">이 장면만 재생성</button>
                    </form>
                  </article>
                <% }) %>
              </div>
            </article>
          <% } %>

          <% if (activeStep === 'render') { %>
            <article class="panel">
              <div class="panel-head">
                <div>
                  <p class="eyebrow">5단계</p>
                  <h2>렌더링 결과</h2>
                </div>
                <form action="/projects/<%= project.id %>/run" method="post">
                  <button type="submit">전체 다시 렌더</button>
                </form>
              </div>

              <div class="link-grid">
                <% if (project.output?.videoPath) { %>
                  <a class="result-link" href="<%= project.output.videoPath.replace(/^.*?storage/, '/storage') %>" target="_blank">완성 영상 열기</a>
                <% } %>
                <% if (project.output?.thumbnailPath) { %>
                  <a class="result-link" href="<%= project.output.thumbnailPath.replace(/^.*?storage/, '/storage') %>" target="_blank">썸네일 열기</a>
                <% } %>
                <% if (project.output?.subtitlesPath) { %>
                  <a class="result-link" href="<%= project.output.subtitlesPath.replace(/^.*?storage/, '/storage') %>" target="_blank">자막 열기</a>
                <% } %>
              </div>
            </article>
          <% } %>

          <% if (activeStep === 'publish') { %>
            <article class="panel stack">
              <div class="panel-head">
                <div>
                  <p class="eyebrow">6단계</p>
                  <h2>업로드 및 연동</h2>
                </div>
              </div>

              <section class="info-box">
                <h3>Google Vids 적용 방법</h3>
                <% googleVidsNotes.forEach((note) => { %>
                  <p><%= note %></p>
                <% }) %>
                <a class="result-link" href="/api/projects/<%= project.id %>/google-vids-package" target="_blank">Google Vids용 자산 패키지 JSON 열기</a>
              </section>

              <section class="info-box">
                <h3>GitHub 연결 상태</h3>
                <p>로컬 Git 준비: <strong><%= githubStatus.localGitReady ? '완료' : '미완료' %></strong></p>
                <p>원격 GitHub 연결: <strong><%= githubStatus.remoteConnected ? '완료' : '대기' %></strong></p>
                <p><%= githubStatus.note %></p>
              </section>

              <section class="info-box">
                <h3>도움말 챗봇</h3>
                <form class="form-grid" action="/projects/<%= project.id %>/help" method="post">
                  <label class="wide">질문
                    <input type="text" name="question" placeholder="예: 업로드는 언제 되나요?" />
                  </label>
                  <div class="wide">
                    <button type="submit">질문하기</button>
                  </div>
                </form>
                <% if (typeof helpAnswer !== 'undefined') { %>
                  <p class="help-answer"><%= helpAnswer %></p>
                <% } %>
              </section>
            </article>
          <% } %>
        </section>
      </section>
    </main>
  </body>
</html>
