<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Longform Factory <%= versionLabel %></title>
    <link rel="stylesheet" href="/public/app.css" />
  </head>
  <body class="app-body dark-body">
    <div class="studio-shell">
      <aside class="studio-sidebar">
        <div class="studio-logo">
          <div class="studio-logo-mark">LF</div>
          <div>
            <strong>Longform Studio</strong>
            <span><%= versionLabel %></span>
          </div>
        </div>

        <nav class="studio-nav">
          <% homeNav.forEach((item) => { %>
            <a class="studio-nav-item <%= item.active ? 'active' : '' %>" href="<%= item.href %>">
              <span class="studio-nav-dot"></span>
              <div>
                <strong><%= item.label %></strong>
                <span><%= item.shortLabel %></span>
              </div>
            </a>
          <% }) %>
        </nav>

        <section class="studio-side-card">
          <p class="section-tag">Workflow</p>
          <ul class="studio-side-list">
            <li>주제 프롬프트 입력</li>
            <li>도출된 주제 확인</li>
            <li>리서치 저장</li>
            <li>길이 기준 대본 생성</li>
            <li>장면 생성과 렌더 확인</li>
            <li>예약 업로드 연동</li>
          </ul>
        </section>
      </aside>

      <main class="studio-main">
        <% if (typeof noticeMessage !== 'undefined' && noticeMessage) { %>
          <section class="notice-banner">
            <strong>알림</strong>
            <span><%= noticeMessage %></span>
          </section>
        <% } %>

        <% if (activeHomeSection === 'dashboard') { %>
          <section class="topbar-card">
            <div>
              <p class="section-tag">Studio Dashboard</p>
              <h1>제작 대시보드</h1>
              <p class="lead-text">대시보드에서 바로 프로젝트를 열고, 단계 화면으로 이동하고, 전체 실행까지 할 수 있습니다.</p>
            </div>
            <div class="form-actions">
              <a class="ghost-button" href="/workspace/create">새 프로젝트</a>
              <a class="inline-link" href="/workspace/projects">보관함</a>
            </div>
          </section>

          <section class="studio-metrics">
            <article class="metric-card primary-metric">
              <span class="metric-label">현재 버전</span>
              <strong><%= versionLabel %></strong>
            </article>
            <article class="metric-card">
              <span class="metric-label">채널 수</span>
              <strong><%= dashboardStats.channelCount %></strong>
            </article>
            <article class="metric-card">
              <span class="metric-label">프로젝트 수</span>
              <strong><%= dashboardStats.projectCount %></strong>
            </article>
            <article class="metric-card">
              <span class="metric-label">완료</span>
              <strong><%= dashboardStats.readyCount %></strong>
            </article>
            <article class="metric-card">
              <span class="metric-label">진행중</span>
              <strong><%= dashboardStats.runningCount %></strong>
            </article>
            <article class="metric-card">
              <span class="metric-label">업로드 대기</span>
              <strong><%= dashboardStats.queuedUploadCount %></strong>
            </article>
          </section>

          <section class="content-grid">
            <section class="content-stack">
              <article class="panel-card">
                <div class="panel-header">
                  <div>
                    <p class="section-tag">Quick Actions</p>
                    <h2>빠른 실행</h2>
                  </div>
                </div>
                <div class="action-grid">
                  <a class="action-card" href="/workspace/create">
                    <strong>새 프로젝트 생성</strong>
                    <p>주제 프롬프트와 영상 길이를 넣고 새 작업을 시작합니다.</p>
                  </a>
                  <a class="action-card" href="/workspace/channels">
                    <strong>업로드 채널 연결</strong>
                    <p>n8n 웹훅과 업로드 채널 정보를 저장합니다.</p>
                  </a>
                  <a class="action-card" href="/workspace/projects">
                    <strong>프로젝트 보관함</strong>
                    <p>기존 프로젝트를 다시 열고 단계별 편집 화면으로 이동합니다.</p>
                  </a>
                </div>
              </article>

              <article class="panel-card">
                <div class="panel-header">
                  <div>
                    <p class="section-tag">Recent Projects</p>
                    <h2>최근 프로젝트</h2>
                  </div>
                </div>
                <div class="dashboard-project-grid">
                  <% if (!projects.length) { %>
                    <div class="empty-card">
                      <strong>프로젝트가 없습니다.</strong>
                      <p>제작 시작 화면에서 첫 프로젝트를 생성해 주세요.</p>
                    </div>
                  <% } %>
                  <% projects.slice(0, 5).forEach((project) => { %>
                    <% const projectTitle = (project.topic || '').split(/\r?\n/)[0].slice(0, 60); %>
                    <article class="panel-card dashboard-project-card">
                      <div class="dashboard-project-head">
                        <div>
                          <strong><%= projectTitle %></strong>
                          <p><%= project.language %> · <%= project.tone %> · <%= project.format %> · 약 <%= project.settings?.durationMinutes || 10 %>분</p>
                        </div>
                        <span class="status-pill <%= project.status %>"><%= project.status %></span>
                      </div>

                      <div class="dashboard-project-actions">
                        <a class="inline-link" href="/projects/<%= project.id %>/topic">주제</a>
                        <a class="inline-link" href="/projects/<%= project.id %>/research">리서치</a>
                        <a class="inline-link" href="/projects/<%= project.id %>/script">대본</a>
                        <a class="inline-link" href="/projects/<%= project.id %>/scenes">장면</a>
                        <a class="inline-link" href="/projects/<%= project.id %>/render">렌더</a>
                        <form action="/projects/<%= project.id %>/run" method="post">
                          <button type="submit">전체 실행</button>
                        </form>
                        <% if (project.output?.videoPath) { %>
                          <a class="inline-link" href="<%= project.output.videoPath.replace(/^.*?storage/, '/storage').replace(/\\/g, '/') %>" target="_blank">영상 열기</a>
                        <% } %>
                        <form action="/projects/<%= project.id %>/delete" method="post" data-delete-project-form>
                          <input type="hidden" name="returnTo" value="dashboard" />
                          <button class="danger-button" type="submit">삭제</button>
                        </form>
                      </div>
                    </article>
                  <% }) %>
                </div>
              </article>
            </section>

            <aside class="content-stack narrow-stack">
              <article class="panel-card">
                <div class="panel-header">
                  <div>
                    <p class="section-tag">Production Flow</p>
                    <h2>작업 흐름</h2>
                  </div>
                </div>
                <div class="timeline-stack">
                  <div class="timeline-row done">
                    <span class="timeline-bullet"></span>
                    <div>
                      <strong>주제 프롬프트 저장</strong>
                      <p>짧은 제목이 아니라 원하는 결과를 문장으로 입력합니다.</p>
                    </div>
                  </div>
                  <div class="timeline-row">
                    <span class="timeline-bullet"></span>
                    <div>
                      <strong>도출된 주제 확인</strong>
                      <p>프롬프트를 저장하면 실제 사용 주제가 자동으로 정리됩니다.</p>
                    </div>
                  </div>
                  <div class="timeline-row">
                    <span class="timeline-bullet"></span>
                    <div>
                      <strong>길이 기준 대본 생성</strong>
                      <p>선택한 영상 길이를 기준으로 자동 대본을 생성합니다.</p>
                    </div>
                  </div>
                  <div class="timeline-row">
                    <span class="timeline-bullet"></span>
                    <div>
                      <strong>장면과 렌더 확인</strong>
                      <p>장면 생성, 음성, 자막, 최종 mp4 결과를 순서대로 확인합니다.</p>
                    </div>
                  </div>
                </div>
              </article>

              <article class="panel-card">
                <div class="panel-header">
                  <div>
                    <p class="section-tag">Queue</p>
                    <h2>현재 상태</h2>
                  </div>
                </div>
                <div class="list-stack">
                  <div class="list-row static-row">
                    <div>
                      <strong>완료</strong>
                      <p>렌더까지 끝난 프로젝트 수</p>
                    </div>
                    <span class="status-pill ready"><%= dashboardStats.readyCount %></span>
                  </div>
                  <div class="list-row static-row">
                    <div>
                      <strong>진행중</strong>
                      <p>현재 처리 중인 프로젝트 수</p>
                    </div>
                    <span class="status-pill running"><%= dashboardStats.runningCount %></span>
                  </div>
                  <div class="list-row static-row">
                    <div>
                      <strong>실패</strong>
                      <p>재확인이 필요한 프로젝트 수</p>
                    </div>
                    <span class="status-pill failed"><%= dashboardStats.failedCount %></span>
                  </div>
                </div>
              </article>
            </aside>
          </section>
        <% } %>

        <% if (activeHomeSection === 'create') { %>
          <section class="topbar-card">
            <div>
              <p class="section-tag">Create Studio</p>
              <h1>새 프로젝트 생성</h1>
              <p class="lead-text">주제 프롬프트를 입력하면 다음 단계에서 실제 사용할 주제가 도출됩니다. 기본 영상 길이는 10분입니다.</p>
            </div>
          </section>

          <section class="content-grid single-column-grid">
            <article class="panel-card">
              <div class="panel-header">
                <div>
                  <p class="section-tag">Project Setup</p>
                  <h2>기본 정보 입력</h2>
                </div>
                <span class="status-chip">Auto + Manual</span>
              </div>

              <form class="form-grid studio-form" action="/projects" method="post" enctype="multipart/form-data">
                <label class="wide">주제 프롬프트
                  <textarea
                    name="topicPrompt"
                    class="prompt-textarea"
                    placeholder="예: BBC 헤드라인 스타일로 오늘 가장 중요한 국제 뉴스 3가지를 정리하고, 각 이슈의 배경과 앞으로의 영향을 설명해 주세요."
                    required
                  ></textarea>
                </label>

                <label>언어
                  <select name="language">
                    <option value="ko">한국어</option>
                    <option value="en">영어</option>
                    <option value="ja">일본어</option>
                  </select>
                </label>

                <label>톤
                  <input type="text" name="tone" value="정보형" />
                </label>

                <label>화면 비율
                  <select name="format">
                    <option value="portrait">세로형 9:16</option>
                    <option value="landscape">가로형 16:9</option>
                  </select>
                </label>

                <label>영상 길이
                  <select name="durationMinutes">
                    <% durationOptions.forEach((minutes) => { %>
                      <option value="<%= minutes %>" <%= minutes === 10 ? 'selected' : '' %>><%= minutes %>분</option>
                    <% }) %>
                  </select>
                </label>

                <label>채널
                  <select name="channelId">
                    <option value="">선택 안 함</option>
                    <% channels.forEach((channel) => { %>
                      <option value="<%= channel.id %>"><%= channel.name %></option>
                    <% }) %>
                  </select>
                </label>

                <label>예약 시작
                  <input type="datetime-local" name="scheduledAt" />
                </label>

                <label class="wide">추가 지시
                  <input type="text" name="customPrompt" placeholder="예: 차분하고 신뢰감 있게, 과장 없는 설명 톤" />
                </label>

                <label>스타일 레퍼런스
                  <input type="file" name="styleReference" accept="image/*" />
                </label>

                <label>BGM 파일
                  <input type="file" name="bgmFile" accept="audio/*" />
                </label>

                <label class="wide">워터마크
                  <input type="file" name="watermarkFile" accept="image/*" />
                </label>

                <div class="wide form-actions">
                  <button type="submit">프로젝트 시작</button>
                </div>
              </form>
            </article>
          </section>
        <% } %>

        <% if (activeHomeSection === 'channels') { %>
          <section class="topbar-card">
            <div>
              <p class="section-tag">Channels</p>
              <h1>업로드 채널 관리</h1>
              <p class="lead-text">유튜브 업로드 자동화를 위한 채널과 n8n 웹훅 주소를 저장합니다.</p>
            </div>
          </section>

          <section class="content-grid">
            <section class="content-stack">
              <article class="panel-card">
                <div class="panel-header">
                  <div>
                    <p class="section-tag">Add Channel</p>
                    <h2>채널 등록</h2>
                  </div>
                </div>
                <form class="form-grid single-form studio-form" action="/channels" method="post">
                  <label>채널 이름
                    <input type="text" name="name" placeholder="메인 유튜브 채널" />
                  </label>
                  <label>플랫폼
                    <input type="text" name="platform" value="youtube" />
                  </label>
                  <label>업로드 웹훅 URL
                    <input type="text" name="uploadWebhookUrl" placeholder="n8n webhook URL" />
                  </label>
                  <div class="form-actions">
                    <button type="submit">채널 저장</button>
                  </div>
                </form>
              </article>
            </section>

            <aside class="content-stack narrow-stack">
              <article class="panel-card">
                <div class="panel-header">
                  <div>
                    <p class="section-tag">Saved</p>
                    <h2>등록 채널</h2>
                  </div>
                </div>
                <div class="list-stack">
                  <% if (!channels.length) { %>
                    <div class="empty-card">
                      <strong>등록된 채널이 없습니다.</strong>
                      <p>먼저 업로드 채널을 추가해 주세요.</p>
                    </div>
                  <% } %>
                  <% channels.forEach((channel) => { %>
                    <div class="list-row static-row">
                      <div>
                        <strong><%= channel.name %></strong>
                        <p><%= channel.platform %></p>
                      </div>
                      <span class="status-pill"><%= channel.upload_webhook_url ? 'webhook' : 'local' %></span>
                    </div>
                  <% }) %>
                </div>
              </article>
            </aside>
          </section>
        <% } %>

        <% if (activeHomeSection === 'projects') { %>
          <section class="topbar-card">
            <div>
              <p class="section-tag">Project Library</p>
              <h1>프로젝트 보관함</h1>
              <p class="lead-text">생성된 프로젝트를 다시 열고 단계별 편집 화면으로 이동합니다.</p>
            </div>
          </section>

          <section class="content-grid single-column-grid">
            <article class="panel-card">
              <div class="panel-header">
                <div>
                  <p class="section-tag">All Projects</p>
                  <h2>전체 프로젝트</h2>
                </div>
              </div>
              <div class="list-stack">
                <% if (!projects.length) { %>
                  <div class="empty-card">
                    <strong>프로젝트가 없습니다.</strong>
                    <p>제작 시작 화면에서 첫 프로젝트를 생성해 주세요.</p>
                  </div>
                <% } %>
                <% projects.forEach((project) => { %>
                  <% const projectTitle = (project.topic || '').split(/\r?\n/)[0].slice(0, 60); %>
                  <a class="list-row large-row" href="/projects/<%= project.id %>/topic">
                    <div>
                      <strong><%= projectTitle %></strong>
                      <p><%= project.language %> · <%= project.tone %> · <%= project.format %> · 약 <%= project.settings?.durationMinutes || 10 %>분</p>
                    </div>
                    <span class="status-pill <%= project.status %>"><%= project.status %></span>
                  </a>
                  <form class="project-delete-row" action="/projects/<%= project.id %>/delete" method="post" data-delete-project-form>
                    <input type="hidden" name="returnTo" value="projects" />
                    <button class="danger-button" type="submit">프로젝트 삭제</button>
                  </form>
                <% }) %>
              </div>
            </article>
          </section>
        <% } %>
      </main>
    </div>
  </body>
</html>
